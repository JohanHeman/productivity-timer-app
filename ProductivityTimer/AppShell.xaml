<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProductivityTimer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ProductivityTimer"
    xmlns:pages="clr-namespace:ProductivityTimer.Views"
    Title="ProductivityTimer">

    <TabBar>

    <ShellContent
        Title="Current Page"
        ContentTemplate="{DataTemplate pages:MainPage}"
        Route="MainPage" />
        
    <ShellContent
        Title="Settings"
        ContentTemplate="{DataTemplate pages:SettingsPage}"
        Route="SettingsPage" />
    </TabBar>


</Shell>