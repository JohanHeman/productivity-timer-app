<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProductivityTimer.MainPage">
           <ContentPage.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B1020" Offset="0.0" />
                <GradientStop Color="#111827" Offset="0.5" />
                <GradientStop Color="#1F2937" Offset="1.0" />
            </LinearGradientBrush>
           </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout 
            VerticalOptions="Center" 
            Spacing="20" 
            Padding="30">
            
            <Label
                Text="{Binding QuoteText}"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                FontSize="18"
                Margin="0,0,0,20"/>

            
            <Grid WidthRequest="220" HeightRequest="50" HorizontalOptions="Center">
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4338CA" Offset="0.0" />
                            <GradientStop Color="#0F766E" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#66000000" Offset="0,6" Radius="12" Opacity="0.7" />
                    </Border.Shadow>
                </Border>
                <Button
                    Text="Work"
                    Style="{StaticResource GradientButtonText}"
                    Command="{Binding WorkNavigationCommand}"
                    />
            </Grid>

            <Grid WidthRequest="220" HeightRequest="50" HorizontalOptions="Center">
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4338CA" Offset="0.0" />
                            <GradientStop Color="#0F766E" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#66000000" Offset="0,6" Radius="12" Opacity="0.7" />
                    </Border.Shadow>
                </Border>
                <Button
                    Text="Review Work History"
                    Style="{StaticResource GradientButtonText}"
                    Command="{Binding HistoryNavigationCommand}"
                    />
            </Grid>

            <Grid WidthRequest="220" HeightRequest="50" HorizontalOptions="Center">
                <Border StrokeThickness="0" StrokeShape="RoundRectangle 14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#4338CA" Offset="0.0" />
                            <GradientStop Color="#0F766E" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#66000000" Offset="0,6" Radius="12" Opacity="0.7" />
                    </Border.Shadow>
                </Border>
                <Button
                    Text="Quit"
                    Style="{StaticResource GradientButtonText}"
                    Command="{Binding QuitCommand}"
                    />
            </Grid>
                
        </VerticalStackLayout>
    </ScrollView>
  
</ContentPage>
